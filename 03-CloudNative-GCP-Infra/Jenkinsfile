pipeline {
    agent any

    parameters {
        string(name: 'GCP_PROJECT_ID', defaultValue: '', description: 'Paste your active rotating playground project ID string here')
    }

    environment {
        TF_IN_AUTOMATION = 'true'
    }

    stages {
        stage('1. Sync Source Code') {
            steps {
                echo '📥 Pulling latest code manifests from your GitHub repository...'
                checkout scm
            }
        }

        stage('2. Initialize Terraform') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🏗️ Clearing cache and reconfiguring local backend tracks...'
                    sh '''
                        rm -rf .terraform/ .terraform.lock.hcl
                        terraform init -reconfigure
                    '''
                }
            }
        }

        stage('3. Verification Plan') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🔍 Extracting secret file and computing architectural plan...'
                    
                    // CRITICAL: Wrap the plan inside withCredentials so it can satisfy the new variable requirement
                    withCredentials([file(credentialsId: 'GCP_SECRET_FILE_KEY', variable: 'SECRET_FILE_PATH')]) {
                        sh '''
                            RAW_KEY=$(cat "$SECRET_FILE_PATH")
                            
                            terraform plan \
                              -var="gcp_project_id=${params.GCP_PROJECT_ID}" \
                              -var="gemini_api_key=$RAW_KEY"
                        '''
                    }
                }
            }
        }

        stage('4. Deploy Infrastructure & Inject Key') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🚀 Extracting secret file and passing key to Terraform...'
                    
                    withCredentials([file(credentialsId: 'GCP_SECRET_FILE_KEY', variable: 'SECRET_FILE_PATH')]) {
                        sh '''
                            RAW_KEY=$(cat "$SECRET_FILE_PATH")
                            
                            # Pass BOTH variables into Terraform dynamically
                            terraform apply \
                              -var="gcp_project_id=${params.GCP_PROJECT_ID}" \
                              -var="gemini_api_key=$RAW_KEY" \
                              -auto-approve
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            echo '🧹 Pipeline execution sequence complete. Cleaning workspace environmental variables...'
        }
    }
}
