pipeline {
    agent any

    parameters {
        string(
            name: 'GCP_PROJECT_ID',
            defaultValue: '',
            description: 'Paste your active rotating playground project ID string here'
        )
    }

    environment {
        TF_IN_AUTOMATION      = 'true'
        // Terraform automatically reads any TF_VAR_ prefixed env variable.
        // This maps directly to var.gcp_project_id in your variables.tf.
        // Since this is not a secret, Groovy interpolation here is fine.
        TF_VAR_gcp_project_id = "${params.GCP_PROJECT_ID}"
    }

    stages {
        stage('1. Sync Source Code') {
            steps {
                echo '📥 Pulling latest code manifests from your GitHub repository...'
                checkout scm
            }
        }

        stage('2. Initialize Terraform') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🏗️ Clearing cache and reconfiguring local backend tracks...'
                    sh '''
                        rm -rf .terraform/ .terraform.lock.hcl
                        terraform init -reconfigure
                    '''
                }
            }
        }

        stage('3. Verification Plan') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🔍 Computing architectural plan...'

                    // withCredentials injects the secret directly as an
                    // environment variable named TF_VAR_gemini_api_key.
                    // Terraform reads it automatically — no -var flag needed.
                    withCredentials([
                        string(credentialsId: 'GEMINI_API_KEY', variable: 'TF_VAR_gemini_api_key')
                    ]) {
                        // Single quotes — Groovy touches nothing in this block.
                        // Both TF_VAR_ variables are already in the environment.
                        sh 'terraform plan'
                    }
                }
            }
        }

        stage('4. Deploy Infrastructure & Inject Key') {
            steps {
                dir('03-CloudNative-GCP-Infra/Terraform') {
                    echo '🚀 Deploying infrastructure and injecting key into VM startup script...'

                    withCredentials([
                        string(credentialsId: 'GEMINI_API_KEY', variable: 'TF_VAR_gemini_api_key')
                    ]) {
                        sh 'terraform apply -auto-approve'
                    }
                }
            }
        }
    }

    post {
        always {
            echo '🧹 Pipeline execution sequence complete. Cleaning workspace...'
        }
    }
}
